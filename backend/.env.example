ENV=development

# Local/demo only placeholder. Replace for any deployed environment.
# Never commit production secrets.
SECRET_KEY=dev-only-change-me-in-production
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///./finance.db

# LLM_PROVIDER: openai | fallback | mock
LLM_PROVIDER=fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=15
LLM_MOCK_TEXT=mock response

# Fundamentals and stock data providers use bounded external requests.
FUNDAMENTALS_PROVIDER=yfinance
FUNDAMENTALS_TTL_HOURS=24
FUNDAMENTALS_TIMEOUT_SECONDS=8
STOCK_DATA_TIMEOUT_SECONDS=8
