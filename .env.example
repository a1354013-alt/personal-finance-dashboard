ENV=development
SECRET_KEY=
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///./finance.db

# --- AI Providers ---
# LLM_PROVIDER: openai | fallback | mock
# - openai: uses OpenAI Responses API (requires OPENAI_API_KEY)
# - fallback: deterministic local heuristic output (never calls external API)
# - mock: test-only provider, returns LLM_MOCK_TEXT
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=15
LLM_MOCK_TEXT=mock response

# --- Fundamentals Providers ---
# FUNDAMENTALS_PROVIDER: yfinance (default)
# - external calls are guarded by FUNDAMENTALS_TIMEOUT_SECONDS
# - screening reads cached DB rows; use /api/stocks/fundamentals/sync to refresh explicitly
FUNDAMENTALS_PROVIDER=yfinance
FUNDAMENTALS_TTL_HOURS=24
FUNDAMENTALS_TIMEOUT_SECONDS=8
