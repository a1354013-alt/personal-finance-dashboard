{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "F5: Start Personal Finance Dashboard",
      "configurations": [
        "Backend API (FastAPI)",
        "Frontend Dev Server",
        "Open Frontend in Browser"
      ],
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "Backend API (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "preLaunchTask": "Bootstrap Backend"
    },
    {
      "name": "Frontend Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 127.0.0.1 --port 5173",
      "cwd": "${workspaceFolder}/frontend",
      "preLaunchTask": "Bootstrap Frontend"
    },
    {
      "name": "Open Frontend in Browser",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "Wait for Frontend"
    }
  ]
}
